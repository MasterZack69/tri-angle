---
import RevealGroup from '@components/motion/RevealGroup';
import RevealItem from '@components/motion/RevealItem';
import RevealLines from '@components/motion/RevealLines';
import RevealFade from '@components/motion/RevealFade';
import ProjectPanel from './work/ProjectPanel.astro';
import type { Project } from './work/ProjectPanel.astro';
import styles from './SelectedWork.module.scss';

const PROJECTS: readonly Project[] = [
  {
    index: '01',
    slug: 'masked11',
    name: 'Masked11',
    category: 'E-Commerce',
    year: '2026',
    description: 'An E-Commerce site for selling jerseys all over India, made the frontend and the backend, handled everything from cute animations to payment and shipping.',
    stack: ['Next.js', 'TypeScript', 'TailwindCSS', 'Hostinger', 'Razorpay', 'WordPress', 'WooCommerce'],
    image: '/work/masked11.webp',
    imageAlt: 'Masked11',
    url: 'https://masked11.in'
  },
  {
    index: '02',
    slug: 'nextok',
    name: 'Nextok',
    category: 'Idk',
    year: '2025',
    description: 'idk tbh fr fr ngl',
    stack: ['React', 'idk'],
    image: '/work/nextok.webp',
    imageAlt: 'Nextok',
    url: 'https://nextok.io'
  },
];
---

<section id="work" class={styles.work} aria-label="Selected Work">
  <div class={styles.inner}>
    <header class={styles.intro}>
      <RevealGroup client:visible className={styles.introGroup} stagger={0.1}>
        <RevealItem as="p" className={styles.index}>
          <span class={styles.indexMark} aria-hidden="true">△</span>
          02 — Selected Work
        </RevealItem>

        <RevealLines
          client:visible
          lines={['Systems we’ve built.']}
          as="h2"
          className={styles.heading}
          lineClassName={styles.headingLine}
          innerClassName={styles.headingInner}
          playKey="work-heading"
        />

      </RevealGroup>
    </header>

    <div class={styles.projects}>
      {
        PROJECTS.map((project, i) => (
          <ProjectPanel
            project={project}
            orientation={i % 2 === 0 ? 'left' : 'right'}
          />
        ))
      }
    </div>
   <footer class={styles.closer}>
</footer>
