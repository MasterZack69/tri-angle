---
import RevealGroup from '@components/motion/RevealGroup';
import RevealItem from '@components/motion/RevealItem';
import RevealLines from '@components/motion/RevealLines';
import ProjectPanel from './work/ProjectPanel.astro';
import type { Project } from './work/ProjectPanel.astro';
import styles from './SelectedWork.module.scss';

const PROJECTS: readonly Project[] = [
  {
    index: '01',
    slug: 'maskedeleven',
    name: 'Masked Eleven',
    category: 'E-Commerce',
    year: '2026',
    description: 'A beautiful site for selling jerseys all over India. Designed for the football enthusiasts, approved by the football enthusiasts.',
    stack: ['Next.js', 'TypeScript', 'TailwindCSS', 'Hostinger', 'WordPress', 'WooCommerce', 'Framer Motion'],
    image: '/work/maskedeleven.webp',
    imageAlt: 'Masked Eleven',
    url: 'https://maskedeleven.com'
  },
  {
    index: '02',
    slug: 'nextok',
    name: 'Nextok',
    category: 'Landing',
    year: '2025',
    description: "A dynamic consultancy landing page built with modern web technologies. Featuring bespoke animations, seamless navigation, and highly optimized performance to show how we can transform your brand's digital presence into a powerful lead-generation tool.",
    stack: ['Next.js', 'TypeScript', 'TailwindCSS', 'Framer Motion'],
    image: '/work/nextok.webp',
    imageAlt: 'Nextok',
    url: 'https://nextok.io'
  },
];
---

<section id="work" class={styles.work} aria-label="Selected Work">
  <div class={styles.inner}>
    <header class={styles.intro}>
      <RevealGroup client:visible className={styles.introGroup} stagger={0.1}>
        <RevealItem as="p" className={styles.index}>
          <span class={styles.indexMark} aria-hidden="true">△</span>
          03 — Selected Work
        </RevealItem>

        <RevealLines
          client:visible
          lines={['Systems we’ve built.']}
          as="h2"
          className={styles.heading}
          lineClassName={styles.headingLine}
          innerClassName={styles.headingInner}
          playKey="work-heading"
        />
      </RevealGroup>
    </header>

    <div class={styles.projects}>
      {
        PROJECTS.map((project, i) => (
          <ProjectPanel
            project={project}
            orientation={i % 2 === 0 ? 'left' : 'right'}
          />
        ))
      }
    </div>
  </div>
</section>
